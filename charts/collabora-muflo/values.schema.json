{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Collabora-muflo values schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "replicaCount",
    "image",
    "probes",
    "deployment",
    "environmentVariablesCool",
    "namespace",
    "resources"
  ],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "app": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "urlScheme", "scaling", "monitoring", "service"],
          "properties": {
            "name": { "type": "string" },
            "urlScheme": {
              "type": "string",
              "enum": ["HTTP", "HTTPS"]
            },
            "scaling": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled", "min", "max", "target"],
              "properties": {
                "enabled": { "type": "boolean" },
                "min": { "type": "integer", "minimum": 1 },
                "max": { "type": "integer", "minimum": 1 },
                "target": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["cpu", "memory"],
                  "properties": {
                    "cpu": { "type": "integer", "minimum": 1, "maximum": 99 },
                    "memory": { "type": "integer", "minimum": 0, "maximum": 99 }
                  }
                }
              }
            },
            "monitoring": {
              "type": "object",
              "additionalProperties": false,
              "required": ["activate", "port", "path"],
              "properties": {
                "activate": { "type": "boolean" },
                "port": { "type": "integer" },
                "path": { "type": "string" }
              }
            },
            "service": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "type", "externalPort", "internalPort"],
              "properties": {
                "name": { "type": "string" },
                "type": {
                  "type": "string",
                  "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
                },
                "externalPort": { "type": "integer" },
                "internalPort": { "type": "integer" }
              }
            }
          }
        },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "tlsissuer", "tlssecret"],
          "properties": {
            "name": { "type": "string" },
            "tlsissuer": { "type": "string" },
            "tlssecret": { "type": "string" }
          }
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name", "annotations"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowPrivilegeEscalation": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pullPolicy", "repository", "tag"],
      "properties": {
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "repository": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["urlScheme", "port", "readiness", "liveness"],
      "properties": {
        "urlScheme": {
          "type": "string",
          "enum": ["HTTP", "HTTPS"]
        },
        "port": { "type": "integer" },
        "readiness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["activate", "path", "initialDelaySeconds", "periodSeconds", "timeoutSeconds", "successThreshold", "failureThreshold"],
          "properties": {
            "activate": { "type": "boolean" },
            "path": { "type": "string" },
            "initialDelaySeconds": { "type": "integer", "minimum": 0 },
            "periodSeconds": { "type": "integer", "minimum": 1 },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "successThreshold": { "type": "integer", "minimum": 1 },
            "failureThreshold": { "type": "integer", "minimum": 1 }
          }
        },
        "liveness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["activate", "path", "initialDelaySeconds", "periodSeconds", "timeoutSeconds", "successThreshold", "failureThreshold"],
          "properties": {
            "activate": { "type": "boolean" },
            "path": { "type": "string" },
            "initialDelaySeconds": { "type": "integer", "minimum": 0 },
            "periodSeconds": { "type": "integer", "minimum": 1 },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "successThreshold": { "type": "integer", "minimum": 1 },
            "failureThreshold": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "minReadySeconds", "maxUnavailable", "maxSurge"],
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["RollingUpdate", "Recreate"]
        },
        "minReadySeconds": { "type": "integer", "minimum": 0 },
        "maxUnavailable": { "type": "integer", "minimum": 0 },
        "maxSurge": { "type": "integer", "minimum": 1 }
      }
    },
    "environmentVariablesCool": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "value": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" }
      }
    },
    "hpa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" }
      }
    },
    "hosts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host"],
      "properties": {
        "host": { "type": "string" }
      }
    },
    "namespace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collabora"],
      "properties": {
        "collabora": { "type": "string" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
